# HDFilmCehennemi Stremio Addon Configuration
# Copy this file to .env and update values

# Server port (default: 7000)
PORT=7000

# Public URL of your addon server (required for TV playback)
BASE_URL=http://localhost:7000

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Main site domain (rotates periodically; default: hdfilmcehennemi.nl)
SITE_DOMAIN=hdfilmcehennemi.nl

# Embed/player host (default: hdfilmcehennemi.mobi)
EMBED_DOMAIN=hdfilmcehennemi.mobi

# Proxy mode: never, auto, always (default: never)
# never = never use proxy (default — direct access works from Turkey)
# auto = use proxy only when Cloudflare geo-blocks (deployments outside Turkey)
# always = always use proxy for hdfilmcehennemi requests
PROXY_ENABLED=never
